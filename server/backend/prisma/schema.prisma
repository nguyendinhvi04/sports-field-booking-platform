// Sports Field Booking Platform - Prisma Schema
// Updated: 2026-03-12

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  OWNER
  ADMIN
}

enum SportType {
  FOOTBALL
  BADMINTON
  TENNIS
  PICKLEBALL
  BASKETBALL
  VOLLEYBALL
  OTHER
}

enum CourtStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
  SUSPENDED
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  LOCKED
}

enum BookingStatus {
  PENDING
  WAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  MOMO
  VNPAY
  CASH
}

enum PaymentStatus {
  PENDING
  WAITING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum RefundStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum NotificationType {
  BOOKING_REMINDER
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SCHEDULE_CHANGED
  PROMOTION
  SYSTEM
  NEWS_FEED
}

enum PostType {
  AVAILABLE_SLOT
  DISCOUNT
  EVENT
  TEAM_MATCHING
  ANNOUNCEMENT
}

enum PostStatus {
  ACTIVE
  HIDDEN
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CustomerTier {
  NORMAL
  SILVER
  GOLD
  VIP
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?   @unique
  passwordHash    String?
  fullName        String
  avatarUrl       String?
  role            Role      @default(USER)
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  isVerified      Boolean   @default(false) // Trạng thái KYC / Hoàn thiện hồ sơ (Đặc biệt cho Owner)
  googleId        String?   @unique
  facebookId      String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  profile          UserProfile?
  sessions         Session[]
  bookings         Booking[]
  reviews          Review[]
  notifications    Notification[]
  favoritesCourts  FavoriteCourt[]
  voucherUsages    VoucherUsage[]
  ownedClubs       Club[]
  passwordResets   PasswordReset[]
  customerProfiles ClubCustomer[]
  ownerProfile     OwnerProfile? // Chỉ tồn tại nếu user.role === 'OWNER'

  @@map("users")
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  address     String?
  dateOfBirth DateTime?
  gender      String?
  bio         String?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ============================================================
// CLUB & COURTS
// ============================================================

model Club {
  id             String         @id @default(cuid())
  ownerId        String
  name           String
  slug           String         @unique
  description    String?
  address        String
  ward           String?
  district       String
  city           String
  latitude       Float?
  longitude      Float?
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  coverImageUrl  String?
  approvalStatus ApprovalStatus @default(PENDING)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id])
  courts       Court[]
  images       ClubImage[]
  openingHours OpeningHour[]
  amenities    ClubAmenity[]
  posts        Post[]
  vouchers     Voucher[]
  customers    ClubCustomer[]

  @@map("clubs")
}

model ClubImage {
  id        String   @id @default(cuid())
  clubId    String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_images")
}

// ============================================================
// OPENING HOURS
// ============================================================

model OpeningHour {
  id        String   @id @default(cuid())
  clubId    String
  dayOfWeek Int // 0=CN, 1=T2, 2=T3, 3=T4, 4=T5, 5=T6, 6=T7
  openTime  DateTime @db.Time // Giờ mở cửa, VD: 06:00:00
  closeTime DateTime @db.Time // Giờ đóng cửa, VD: 23:00:00
  isClosed  Boolean  @default(false) // true = nghỉ nguyên ngày đó
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, dayOfWeek])
  @@map("opening_hours")
}

// ============================================================
// AMENITIES
// ============================================================

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique // "WiFi", "Canteen", "Parking", "Shower", "Locker"...
  icon      String? // Tên icon (VD: "wifi", "utensils", "car")
  createdAt DateTime @default(now())

  clubs ClubAmenity[]

  @@map("amenities")
}

model ClubAmenity {
  id        String   @id @default(cuid())
  clubId    String
  amenityId String
  note      String? // Ghi chú thêm: "WiFi miễn phí", "Canteen tầng 1"...
  createdAt DateTime @default(now())

  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([clubId, amenityId])
  @@map("club_amenities")
}

// ============================================================
// COURTS
// ============================================================

model Court {
  id            String      @id @default(cuid())
  clubId        String
  name          String
  description   String?
  sportType     SportType
  status        CourtStatus @default(ACTIVE)
  capacity      Int?
  surface       String? // "Cỏ nhân tạo", "Sàn gỗ", "Bê tông"...
  indoorOutdoor String? // "INDOOR" / "OUTDOOR"
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  club      Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  images    CourtImage[]
  pricings        CourtPricing[]
  specialPricings SpecialDatePricing[]
  timeSlots       TimeSlot[]
  bookings  Booking[]
  favoredBy FavoriteCourt[]

  @@map("courts")
}

model CourtImage {
  id        String   @id @default(cuid())
  courtId   String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_images")
}

model CourtPricing {
  id           String   @id @default(cuid())
  courtId      String
  dayOfWeek    Int? // 0=CN...6=T7. null = áp dụng mọi ngày
  startTime    DateTime @db.Time // VD: 06:00:00
  endTime      DateTime @db.Time // VD: 12:00:00
  pricePerHour Decimal  @db.Decimal(12, 2)
  label        String? // "Giờ sáng", "Giờ vàng", "Cuối tuần"...
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_pricings")
}

model SpecialDatePricing {
  id           String   @id @default(cuid())
  courtId      String
  specificDate DateTime @db.Date // Ngày cụ thể: 2026-04-30
  startTime    DateTime @db.Time
  endTime      DateTime @db.Time
  pricePerHour Decimal  @db.Decimal(12, 2)
  note         String? // "Lễ 30/4", "Tết Nguyên Đán"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("special_date_pricings")
}

// ============================================================
// TIME SLOTS & BOOKING
// ============================================================

model TimeSlot {
  id        String         @id @default(cuid())
  courtId   String
  startTime DateTime // Full DateTime: "2026-03-15T08:00:00"
  endTime   DateTime // Full DateTime: "2026-03-15T09:00:00"
  status    TimeSlotStatus @default(AVAILABLE)
  lockedBy  String? // userId đang giữ slot tạm thời
  lockedAt  DateTime?
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  court        Court         @relation(fields: [courtId], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]

  @@unique([courtId, startTime])
  @@map("time_slots")
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  courtId        String
  bookingCode    String        @unique @default(cuid())
  status         BookingStatus @default(PENDING)
  totalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal       @db.Decimal(12, 2)
  note           String?
  voucherId      String?
  // Thông tin người đặt
  bookerName     String
  bookerPhone    String
  bookerEmail    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  court         Court          @relation(fields: [courtId], references: [id])
  voucher       Voucher?       @relation(fields: [voucherId], references: [id])
  items         BookingItem[]
  payment       Payment?
  review        Review?
  notifications Notification[]

  @@map("bookings")
}

model BookingItem {
  id         String   @id @default(cuid())
  bookingId  String
  timeSlotId String
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id])

  @@unique([bookingId, timeSlotId])
  @@map("booking_items")
}

// ============================================================
// PAYMENT & REFUND
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  transactionRef  String?       @unique
  bankName        String?
  accountNumber   String?
  transferContent String?
  proofImageUrl   String?
  paidAt          DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?

  // Chính sách hoàn tiền
  refundStatus    RefundStatus @default(NONE)
  refundAmount    Decimal?     @db.Decimal(12, 2) // Số tiền được hoàn lại
  refundReason    String? // Lý do yêu cầu hoàn tiền
  refundRequestAt DateTime? // Thời điểm user gửi yêu cầu
  refundReviewAt  DateTime? // Thời điểm owner/admin xét duyệt
  refundReviewBy  String? // ID người xét duyệt
  refundNote      String? // Ghi chú của người xét duyệt
  refundedAt      DateTime? // Thời điểm hoàn tiền thực tế

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id        String   @id @default(cuid())
  userId    String
  bookingId String   @unique
  courtId   String?
  clubId    String?
  rating    Int // 1–5
  comment   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  booking Booking       @relation(fields: [bookingId], references: [id])
  images  ReviewImage[]

  @@map("reviews")
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

// ============================================================
// VOUCHER & PROMOTION
// ============================================================

model Voucher {
  id             String      @id @default(cuid())
  clubId         String? // null = toàn hệ thống (admin tạo)
  code           String      @unique
  title          String
  description    String?
  type           VoucherType
  value          Decimal     @db.Decimal(12, 2)
  minOrderAmount Decimal?    @db.Decimal(12, 2)
  maxDiscount    Decimal?    @db.Decimal(12, 2)
  usageLimit     Int?
  usagePerUser   Int         @default(1)
  usedCount      Int         @default(0)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  club     Club?          @relation(fields: [clubId], references: [id])
  usages   VoucherUsage[]
  bookings Booking[]

  @@map("vouchers")
}

model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  userId    String
  usedAt    DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([voucherId, userId])
  @@map("voucher_usages")
}

// ============================================================
// FAVORITE COURTS
// ============================================================

model FavoriteCourt {
  id        String   @id @default(cuid())
  userId    String
  courtId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([userId, courtId])
  @@map("favorite_courts")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  bookingId String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("notifications")
}

// ============================================================
// NEWS FEED / POSTS
// ============================================================

model Post {
  id            String     @id @default(cuid())
  clubId        String
  type          PostType
  status        PostStatus @default(ACTIVE)
  title         String
  content       String
  imageUrl      String?
  linkedCourtId String?
  linkedDate    DateTime?
  expiresAt     DateTime?
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("posts")
}

// ============================================================
// OWNER CRM
// ============================================================

model ClubCustomer {
  id            String       @id @default(cuid())
  clubId        String
  userId        String
  tier          CustomerTier @default(NORMAL)
  totalBookings Int          @default(0)
  totalCancels  Int          @default(0)
  totalSpent    Decimal      @default(0) @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_customers")
}

// ============================================================
// OWNER PROFILE (KYC + PAYOUT)
// ============================================================

model OwnerProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique

  // Thông tin định danh cá nhân (KYC)
  idCardNumber       String?        // Số CCCD / CMND
  idCardFrontUrl     String?        // Ảnh CCCD mặt trước
  idCardBackUrl      String?        // Ảnh CCCD mặt sau
  businessLicenseUrl String?        // Ảnh Giấy phép kinh doanh (không bắt buộc)
  taxCode            String?        // Mã số thuế doanh nghiệp

  // Tài khoản ngân hàng nhận tiền (Payout)
  bankName           String?        // VD: "Vietcombank", "Techcombank"
  bankAccountNumber  String?        // Số tài khoản ngân hàng
  bankAccountName    String?        // Tên chủ tài khoản (CHỮ HOA, khớp tên pháp lý)

  // Quy định vận hành mặc định
  cancellationPolicy String?        // VD: "Hủy trước 24h hoàn 100%, sau đó không hoàn..."

  // Trạng thái duyệt hồ sơ KYC bởi Admin
  kycStatus          ApprovalStatus @default(PENDING)
  kycReviewedAt      DateTime?      // Thời điểm Admin xét duyệt
  kycReviewedBy      String?        // ID của Admin đã duyệt
  kycNote            String?        // Ghi chú / Lý do từ chối của Admin

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_profiles")
}
